datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  password      String
  role          Role
  createdAt     DateTime      @default(now())
  applications  Application[]
  opportunities Opportunity[]
}

model Opportunity {
  id           String        @id @default(cuid())
  title        String
  description  String
  address      String
  latitude     Float
  longitude    Float
  date         DateTime
  postedBy     User          @relation(fields: [createdById], references: [id])
  createdById  String
  applications Application[]
}

model Application {
  id            String      @id @default(cuid())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  opportunityId String
  applicant     User        @relation(fields: [applicantId], references: [id])
  applicantId   String
  createdAt     DateTime    @default(now())
}

enum Role {
  VOLUNTEER
  ORGANIZATION
}
